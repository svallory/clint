{
  "name": "@svallory/clint",
  "version": "0.3.0",
  "description": "Claude Code Command Center — calm, decisive, always in control",
  "type": "module",
  "license": "MIT",
  "author": "Saulo Vallory",
  "homepage": "https://clint.saulo.engineer",
  "repository": {
    "type": "git",
    "url": "https://github.com/svallory/clint.git"
  },
  "bugs": "https://github.com/svallory/clint/issues",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "remote-control",
    "telegram",
    "tmux",
    "worktree",
    "ai",
    "anthropic"
  ],
  "bin": {
    "clint": "./bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "CLAUDE.md",
    "oclif.manifest.json"
  ],
  "oclif": {
    "bin": "clint",
    "dirname": "clint",
    "commands": {
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "topicSeparator": " "
  },
  "scripts": {
    "dev": "bun ./bin/dev.ts",
    "build": "tsc",
    "postbuild": "bunx oclif manifest",
    "prepublishOnly": "bun run build",
    "docs:dev": "bunx docmd dev --config ./docmd.config.cjs",
    "docs:build": "bunx docmd build --config ./docmd.config.cjs",
    "test": "bun test"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "@oclif/core": "^4",
    "smol-toml": "^1"
  },
  "devDependencies": {
    "@docmd/core": "^0.6.2",
    "@types/bun": "latest",
    "oclif": "^4",
    "typescript": "^5"
  }
}
